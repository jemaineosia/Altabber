<Window x:Class="AltTabber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aion AltTabber" Height="560" Width="440"
        ResizeMode="NoResize">
    <StackPanel Margin="20">

        <TextBlock Text="Target Process:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="ProcessComboBox" Height="30" Margin="0,0,0,6"/>
        <Button x:Name="RefreshButton" Content="Refresh Processes" Click="RefreshProcesses_Click" Margin="0,0,0,16"/>

        <Border Background="#f0f4ff" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock FontWeight="Bold" Foreground="#2c3e50"
                           Text="Timer 1 - Stay on TARGET app for how long?"/>
                <TextBlock Text="(before switching to YOUR app)" Foreground="Gray" FontSize="11" Margin="0,2,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Min: " VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                    <TextBox x:Name="TargetMinutesBox" Text="30" Width="55" Height="28" TextAlignment="Center"/>
                    <TextBlock Text=" min  " VerticalAlignment="Center"/>
                    <TextBox x:Name="TargetSecondsBox" Text="0" Width="55" Height="28" TextAlignment="Center"/>
                    <TextBlock Text=" sec" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Max: " VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                    <TextBox x:Name="TargetMaxMinutesBox" Text="45" Width="55" Height="28" TextAlignment="Center"/>
                    <TextBlock Text=" min  " VerticalAlignment="Center"/>
                    <TextBox x:Name="TargetMaxSecondsBox" Text="0" Width="55" Height="28" TextAlignment="Center"/>
                    <TextBlock Text=" sec" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="(leave Max same as Min to use a fixed duration)" Foreground="Gray" FontSize="10" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="#fff7f0" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock FontWeight="Bold" Foreground="#2c3e50"
                           Text="Timer 2 - Stay on YOUR app for how long?"/>
                <TextBlock Text="(before switching back to target app)" Foreground="Gray" FontSize="11" Margin="0,2,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="MyAppMinutesBox" Text="5" Width="60" Height="28" TextAlignment="Center"/>
                    <TextBlock Text=" min  " VerticalAlignment="Center"/>
                    <TextBox x:Name="MyAppSecondsBox" Text="0" Width="60" Height="28" TextAlignment="Center"/>
                    <TextBlock Text=" sec" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="StartButton" Content="Start" Width="120" Height="35"
                    Click="Start_Click" Background="#2ecc71" Foreground="White"
                    FontWeight="Bold" Margin="0,0,10,0"/>
            <Button x:Name="StopButton" Content="Stop" Width="120" Height="35"
                    Click="Stop_Click" Background="#e74c3c" Foreground="White"
                    FontWeight="Bold" IsEnabled="False"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Text="Status: Idle" Margin="0,14,0,0"
                   HorizontalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>

        <TextBlock x:Name="CountdownText" Text="" Margin="0,4,0,0"
                   HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#2980b9"/>

        <TextBlock x:Name="StartTimeText" Text="" Margin="0,6,0,0"
                   HorizontalAlignment="Center" FontSize="11" Foreground="Gray"/>
    </StackPanel>
</Window>
